NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key da instância (Kong → SERVICE_ROLE_KEY). Nunca prefixar com
# NEXT_PUBLIC_ — só é lida no servidor (src/lib/supabase/admin.ts), usada
# para criar login de novos usuários via Auth Admin API. Sem ela, tudo em
# /admin/usuarios funciona exceto "Novo usuário".
SUPABASE_SERVICE_ROLE_KEY=
